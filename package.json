{
  "name": "@githosted/sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for githosted — git-backed storage for AI agents",
  "type": "module",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser/index.d.ts",
        "import": "./dist/browser/index.js"
      },
      "node": {
        "types": "./dist/node/index.d.ts",
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      }
    },
    "./proto": {
      "types": "./dist/proto/index.d.ts",
      "import": "./dist/proto/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.0.0",
    "@connectrpc/connect": "^2.0.0",
    "@connectrpc/connect-node": "^2.0.0",
    "@connectrpc/connect-web": "^2.0.0"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5",
    "react": "^19"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@bufbuild/buf": "latest",
    "@bufbuild/protoc-gen-es": "^2.0.0",
    "@tanstack/react-query": "^5",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "react": "^19",
    "tsup": "^8",
    "typescript": "^5.7"
  },
  "license": "MIT",
  "homepage": "https://githosted.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/githosted-dev/typescript-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/githosted-dev/typescript-sdk/issues"
  }
}
